generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProductStatus {
  ACTIVE
  PROMOTION
  HIDDEN
}

enum CategoryStatus {
  ACTIVE
  PROMOTION
  HIDDEN
}

enum SupplierStatus {
  ACTIVE
  PENDING
  INACTIVE
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

model Store {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  active      Boolean         @default(true)
  users       User[]
  inventories Inventory[]
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role           @default(EMPLOYEE)
  active        Boolean        @default(true)
  storeId       String?
  store         Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  movements     StockMovement[]
  priceChanges  PriceHistory[]
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([storeId])
}

model RefreshToken {
  id        String    @id
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, revokedAt])
}

model Category {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String         @default("#25d3b0")
  icon        String         @default("tag")
  status      CategoryStatus @default(ACTIVE)
  products    Product[]
  priceRules  PriceRule[]
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, deletedAt])
}

model Supplier {
  id            String             @id @default(cuid())
  name          String             @unique
  contactName   String
  contactRole   String?
  email         String?
  phone         String?
  creditDays    Int                @default(0)
  paymentMethod String?
  status        SupplierStatus     @default(ACTIVE)
  products      ProductSupplier[]
  deletedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, deletedAt])
}

model Product {
  id            String            @id @default(cuid())
  sku           String            @unique
  barcode       String?           @unique
  name          String
  description   String?
  brand         String?
  unit          String            @default("Pieza")
  purchasePrice Decimal           @db.Decimal(12, 2)
  salePrice     Decimal           @db.Decimal(12, 2)
  minimumStock  Int               @default(0)
  status        ProductStatus     @default(ACTIVE)
  categoryId    String?
  category      Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  suppliers     ProductSupplier[]
  inventories   Inventory[]
  movements     StockMovement[]
  priceHistory  PriceHistory[]
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([name])
  @@index([categoryId, status, deletedAt])
}

model ProductSupplier {
  productId  String
  supplierId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierSku String?
  cost        Decimal? @db.Decimal(12, 2)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@id([productId, supplierId])
  @@index([supplierId])
}

model Inventory {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock     Int      @default(0)
  reserved  Int      @default(0)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
  @@index([productId])
  @@index([storeId, stock])
}

model StockMovement {
  id          String       @id @default(cuid())
  type        MovementType
  quantity    Int
  beforeStock Int
  afterStock  Int
  reason      String?
  reference   String?
  storeId     String
  productId   String
  actorUserId String
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  actor       User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now())

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
}

model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  changedById String
  oldPrice    Decimal  @db.Decimal(12, 2)
  newPrice    Decimal  @db.Decimal(12, 2)
  reason      String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  changedBy   User     @relation(fields: [changedById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([productId, createdAt])
}

model PriceRule {
  id         String   @id @default(cuid())
  name       String
  type       String
  value      Decimal  @db.Decimal(12, 4)
  active     Boolean  @default(true)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId, active])
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  action    String
  data      Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}
