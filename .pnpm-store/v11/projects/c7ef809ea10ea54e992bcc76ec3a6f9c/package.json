    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "prisma": "6.19.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
